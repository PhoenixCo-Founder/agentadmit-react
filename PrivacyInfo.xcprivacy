<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- The SDK does not engage in tracking as defined by ATT -->
  <key>NSPrivacyTracking</key>
  <false/>
  
  <!-- No tracking domains -->
  <key>NSPrivacyTrackingDomains</key>
  <array/>
  
  <!-- No data collected by the SDK itself.
       The SDK transmits data provided by the host app (auth token, scope selections)
       to the host app's own API endpoint. It does not independently collect user data. -->
  <key>NSPrivacyCollectedDataTypes</key>
  <array/>
  
  <!-- No Required Reason APIs used.
       The SDK uses only: fetch (network), React state (memory),
       navigator.clipboard (user-initiated copy action).
       None of these are in Apple's Required Reason API list. -->
  <key>NSPrivacyAccessedAPITypes</key>
  <array/>
</dict>
</plist>
