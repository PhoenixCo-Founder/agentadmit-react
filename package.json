{
  "name": "@agentadmit/react",
  "version": "1.3.0",
  "description": "AgentAdmit React components: drop-in AI Agent Access page for any app",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "style": "dist/styles/agent-admit-panel.css",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./styles": "./dist/styles/agent-admit-panel.css",
    "./styles.css": "./dist/styles/agent-admit-panel.css",
    "./dist/styles/agent-admit-panel.css": "./dist/styles/agent-admit-panel.css"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean && mkdir -p dist/styles && cp src/styles/agent-admit-panel.css dist/styles/agent-admit-panel.css",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "18.3.28",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tsup": "8.5.1",
    "typescript": "5.9.3"
  },
  "license": "SEE LICENSE IN LICENSE",
  "author": "Christopher Emerson",
  "keywords": [
    "agentadmit",
    "react",
    "ai-agent",
    "authorization",
    "components"
  ],
  "files": [
    "dist",
    "PrivacyInfo.xcprivacy",
    "src/styles"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/PhoenixCo-Founder/agentadmit-react.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "dependencies": {
    "@simplewebauthn/browser": "13.3.0"
  }
}
